    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Login Admin (set adminToken + token)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{gatewayBaseUrl}}/api/v1/auth/login", "host": ["{{gatewayBaseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const data = pm.response.json();",
                "if (data && data.access_token) {",
                "  pm.collectionVariables.set('adminToken', data.access_token);",
                "  pm.collectionVariables.set('token', data.access_token);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Login Dispatcher (set dispatcherToken)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{dispatcherEmail}}\",\n  \"password\": \"{{dispatcherPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{gatewayBaseUrl}}/api/v1/auth/login", "host": ["{{gatewayBaseUrl}}"], "path": ["api", "v1", "auth", "login"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const data = pm.response.json();",
                "if (data && data.access_token) {",
                "  pm.collectionVariables.set('dispatcherToken', data.access_token);",
                "}"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "2. Users (Gateway)",
      "item": [
        {
          "name": "Get My User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{gatewayBaseUrl}}/api/v1/users/me", "host": ["{{gatewayBaseUrl}}"], "path": ["api", "v1", "users", "me"] }
          }
        },
        {
          "name": "Patch My User (JSON)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"theme\": \"dark\",\n  \"language\": \"es\",\n  \"email_alerts\": true,\n  \"sms_urgent_alerts\": false,\n  \"browser_notifications\": true,\n  \"employee_id\": \"EMP-0099\",\n  \"office_location\": \"HQ - Lima\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{gatewayBaseUrl}}/api/v1/users/me", "host": ["{{gatewayBaseUrl}}"], "path": ["api", "v1", "users", "me"] }
          }
        },
        {
          "name": "Patch My User (Multipart + Image)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "theme", "type": "text", "value": "dark" },
                { "key": "language", "type": "text", "value": "es" },
                { "key": "email_alerts", "type": "text", "value": "true" },
                { "key": "sms_urgent_alerts", "type": "text", "value": "false" },
                { "key": "browser_notifications", "type": "text", "value": "true" }
              ]
            },
            "url": { "raw": "{{gatewayBaseUrl}}/api/v1/users/me", "host": ["{{gatewayBaseUrl}}"], "path": ["api", "v1", "users", "me"] }
          }
        },
        {
          "name": "List Users (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{gatewayBaseUrl}}/api/v1/users", "host": ["{{gatewayBaseUrl}}"], "path": ["api", "v1", "users"] }
          },
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "const data = pm.response.json();",
                "if (Array.isArray(data)) {",
                "  const target = data.find(u => u.email !== pm.collectionVariables.get('adminEmail'));",
                "  if (target && target.id) pm.collectionVariables.set('targetUserId', target.id);",
                "}"
              ]
            }
          }]
        },
        {
          "name": "Create User (Admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nuevo.operador+{{$timestamp}}@terra.local\",\n  \"full_name\": \"Nuevo Operador\",\n  \"role\": \"dispatcher\",\n  \"password\": \"secret123\",\n  \"theme\": \"light\",\n  \"language\": \"es\",\n  \"email_alerts\": true,\n  \"sms_urgent_alerts\": true,\n  \"browser_notifications\": true,\n  \"employee_id\": \"EMP-{{$timestamp}}\",\n  \"office_location\": \"Operations Center\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{gatewayBaseUrl}}/api/v1/users", "host": ["{{gatewayBaseUrl}}"], "path": ["api", "v1", "users"] }
          }
        },
        {
          "name": "Patch Any User (Admin, JSON)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Dispatch Operator Updated\",\n  \"theme\": \"dark\",\n  \"office_location\": \"Night Shift Office\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{gatewayBaseUrl}}/api/v1/users/{{targetUserId}}", "host": ["{{gatewayBaseUrl}}"], "path": ["api", "v1", "users", "{{targetUserId}}"] }
          }
        },
        {
          "name": "Patch Any User (Admin, Multipart + Image)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "" },
                { "key": "theme", "type": "text", "value": "dark" },
                { "key": "language", "type": "text", "value": "es" }
              ]
            },
            "url": { "raw": "{{gatewayBaseUrl}}/api/v1/users/{{targetUserId}}", "host": ["{{gatewayBaseUrl}}"], "path": ["api", "v1", "users", "{{targetUserId}}"] }
          }
        }
      ]
    },
