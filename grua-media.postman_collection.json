  "item": [
    {
      "name": "0. Health Checks",
      "item": [
        {
          "name": "Gateway Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{gatewayBaseUrl}}/api/health", "host": ["{{gatewayBaseUrl}}"], "path": ["api", "health"] }
          }
        },
        {
          "name": "Auth Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{authBaseUrl}}/health", "host": ["{{authBaseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "Dispatch Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{dispatchBaseUrl}}/health", "host": ["{{dispatchBaseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "Fleet Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{fleetBaseUrl}}/health", "host": ["{{fleetBaseUrl}}"], "path": ["health"] }
          }
        },
        {
          "name": "Clients Health",
          "request": {
            "method": "GET",
            "url": { "raw": "{{clientsBaseUrl}}/health", "host": ["{{clientsBaseUrl}}"], "path": ["health"] }
